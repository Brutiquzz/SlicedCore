{
  "$schema": "http://json.schemastore.org/template",
  "author": "Thomas Poulsen",
  "classifications": [ "My", "Project" ],
  "identity": "Brutiquzz.Template.Project",
  "name": "Project Template",
  "shortName": "my-web",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "ProjectTemplate",
  "preferNameDirectory": true,
  "sources": [
    {
      "source": "./",
      "target": "./",
      "exclude": [
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
        "**/*.user",
        ".template.config",
        ".template.config/**",
        "**/.template.config/**",
        "**/.template/**",
        "**/Generated/**",
        "**/*.http",
        ".git/**",
        ".vs/**",
        "item-templates/**",
        "temp/**",
        "local-inspect/**"
      ]
    }
  ]
}
