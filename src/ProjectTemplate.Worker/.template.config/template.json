{
  "$schema": "http://json.schemastore.org/template",
  "author": "Brutiquzz",
  "classifications": [ "Worker", "SlicedCore" ],
  "identity": "Brutiquzz.Template.Worker",
  "name": "SlicedCore Worker",
  "shortName": "my-worker",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "ProjectTemplate",
  "preferNameDirectory": true,
  "sources": [
    {
      "source": "./",
      "target": "./",
      "exclude": [
        "**/[Bb]in/**",
        "**/[Oo]bj/**",
        "**/*.user",
        ".template.config",
        ".template.config/**",
        "**/.template.config/**",
        "**/.template/**",
        "**/Generated/**",
        ".git/**",
        ".vs/**"
      ]
    }
  ]
}
