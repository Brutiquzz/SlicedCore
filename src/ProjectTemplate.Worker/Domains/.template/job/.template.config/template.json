{
  "$schema": "http://json.schemastore.org/template",
  "author": "Brutiquzz",
  "classifications": [ "Job", "Worker", "Template" ],
  "identity": "Brutiquzz.Templates.Job",
  "name": "Worker Job Template",
  "shortName": "job",
  "tags": {
    "language": "C#",
    "type": "item"
  },
  "sourceName": "CreateSampleJob",
  "preferNameDirectory": false,
  "symbols": {
    "projectName": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "ProjectTemplate",
      "replaces": "ProjectTemplate",
      "description": "The root namespace / project name of the target worker solution"
    },
    "domainName": {
      "type": "generated",
      "generator": "regex",
      "datatype": "string",
      "parameters": {
        "source": "name",
        "steps": [
          {
            "regex": "^(?:Create|Get|Update|Delete|List|Patch|Sync|Process|Cleanup)?(.+?)(?:Job)?$",
            "replacement": "$1"
          }
        ]
      },
      "replaces": "Sample",
      "description": "Domain name derived from the job name by stripping a leading verb prefix and an optional 'Job' suffix"
    },
    "cronExpression": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "0 * * * * *",
      "replaces": "0 * * * * *",
      "description": "The TickerQ cron expression that controls the job's recurring schedule (default: every minute)."
    }
  },
  "sources": [
    {
      "source": ".",
      "include": [
        "CreateSampleJob.cs",
        "CreateSampleJob.Contracts.cs",
        "CreateSampleJob.Job.cs"
      ]
    }
  ]
}
