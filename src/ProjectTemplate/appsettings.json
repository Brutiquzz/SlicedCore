{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=ProjectTemplate;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Cors": {
    "AllowedOrigins": [ "https://localhost:3000" ],
    "AllowedMethods": [ "GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS" ],
    "AllowedHeaders": [ "Authorization", "Content-Type", "X-Api-Version" ],
    "AllowCredentials": true
  },
  "JwtBearer": {
    "Authority": "https://your-idp.example.com",
    "Audience": "your-api-audience",
    "RequireHttpsMetadata": true
  },
  "HmacRedactorOptions": {
    "Key": "REPLACE-THIS-KEY-IN-PRODUCTION-VIA-SECRET-MANAGER",
    "KeyId": 1
  },
  "Resilience": {
    "Retry": {
      "MaxRetryAttempts": 4,
      "DelaySeconds": 2,
      "UseJitter": true,
      "BackoffType": "Exponential"
    },
    "CircuitBreaker": {
      "FailureRatio": 0.5,
      "SamplingDurationSeconds": 30,
      "MinimumThroughput": 10,
      "BreakDurationSeconds": 15
    },
    "Timeout": {
      "AttemptTimeoutSeconds": 10
    }
  },
  "Cache": {
    "DefaultTtlSeconds": 300,
    "Redis": {
      "ConnectionString": "",
      "InstanceName": "slicedcore:"
    }
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "QueueLimit": 10
    },
    "Fixed": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 5
    },
    "Sliding": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "SegmentsPerWindow": 6,
      "QueueLimit": 5
    },
    "Token": {
      "TokenLimit": 100,
      "TokensPerPeriod": 20,
      "ReplenishmentPeriodSeconds": 10,
      "QueueLimit": 10
    },
    "Strict": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  }
}
