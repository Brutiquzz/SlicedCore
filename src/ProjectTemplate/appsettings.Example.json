{
  "$schema": "https://json.schemastore.org/appsettings.json",
  "ConnectionStrings": {
    "DefaultConnection": "Server=your-sql-server;Database=YourDatabase;User Id=your-user;Password=your-password;TrustServerCertificate=True"
  },
  "JwtBearer": {
    "Authority": "https://your-identity-provider.example.com",
    "Audience": "your-api-audience-identifier",
    "RequireHttpsMetadata": true
  },
  "HmacRedactorOptions": {
    "KeyId": 1,
    "Key": "REPLACE-WITH-BASE64-KEY-FROM-SECRET-MANAGER"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Resilience": {
    "Retry": {
      "MaxRetryAttempts": 4,
      "DelaySeconds": 2,
      "UseJitter": true,
      "BackoffType": "Exponential"
    },
    "CircuitBreaker": {
      "FailureRatio": 0.5,
      "SamplingDurationSeconds": 30,
      "MinimumThroughput": 10,
      "BreakDurationSeconds": 15
    },
    "Timeout": {
      "AttemptTimeoutSeconds": 10
    }
  },
  "Cache": {
    "DefaultTtlSeconds": 300,
    "Redis": {
      "ConnectionString": "",
      "InstanceName": "slicedcore:"
    }
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "QueueLimit": 10
    },
    "Fixed": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 5
    },
    "Sliding": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "SegmentsPerWindow": 6,
      "QueueLimit": 5
    },
    "Token": {
      "TokenLimit": 100,
      "TokensPerPeriod": 20,
      "ReplenishmentPeriodSeconds": 10,
      "QueueLimit": 10
    },
    "Strict": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  }
}
