{
  "$schema": "http://json.schemastore.org/template",
  "author": "Brutiquzz",
  "classifications": [ "Feature", "Template" ],
  "identity": "Brutiquzz.Templates.Feature",
  "name": "Feature Template",
  "shortName": "feature",
  "tags": {
    "language": "C#",
    "type": "item"
  },
  "sourceName": "CreateSample",
  "preferNameDirectory": false,
  "symbols": {
    "projectName": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "ProjectTemplate",
      "replaces": "ProjectTemplate",
      "description": "The root namespace / project name of the target solution"
    },
    "domainName": {
      "type": "generated",
      "generator": "regex",
      "datatype": "string",
      "parameters": {
        "source": "name",
        "steps": [
          {
            "regex": "^(?:Create|Get|Update|Delete|List|Patch)(.+)$",
            "replacement": "$1"
          }
        ]
      },
      "replaces": "Sample",
      "description": "Domain name derived from feature name by stripping the verb prefix"
    },
    "operation": {
      "type": "parameter",
      "datatype": "choice",
      "defaultValue": "POST",
      "description": "The HTTP operation this feature represents. Determines the endpoint HTTP method, route pattern, and generated infrastructure shape.",
      "choices": [
        {
          "choice": "GET",
          "description": "Read-only retrieval. Generates a GET endpoint with a route-parameter request, Result.Ok / Result.NotFound responses, and read infrastructure (FirstOrDefaultAsync)."
        },
        {
          "choice": "POST",
          "description": "Resource creation. Generates a POST endpoint with a JSON body request, Result.Created response, and write infrastructure (Add + SaveChangesAsync)."
        },
        {
          "choice": "PUT",
          "description": "Full resource replacement. Generates a PUT endpoint with a route parameter and JSON body request, Result.Ok / Result.NotFound responses, and update infrastructure."
        },
        {
          "choice": "PATCH",
          "description": "Partial resource update. Generates a PATCH endpoint with a route parameter and JSON body request, Result.Ok / Result.NotFound responses, and update infrastructure."
        },
        {
          "choice": "DELETE",
          "description": "Resource deletion. Generates a DELETE endpoint with a route-parameter request, Result.Ok / Result.NotFound responses, and delete infrastructure."
        }
      ]
    },
    "featureType": {
      "type": "generated",
      "generator": "regex",
      "datatype": "string",
      "parameters": {
        "source": "operation",
        "steps": [
          {
            "regex": "^GET$",
            "replacement": "query"
          },
          {
            "regex": "^(POST|PUT|PATCH|DELETE)$",
            "replacement": "command"
          }
        ]
      },
      "description": "Derived CQRS feature type: 'query' for GET, 'command' for all other operations."
    },
    "isCommand": {
      "type": "computed",
      "value": "(featureType == \"command\")"
    },
    "isQuery": {
      "type": "computed",
      "value": "(featureType == \"query\")"
    },
    "isGet": {
      "type": "computed",
      "value": "(operation == \"GET\")"
    },
    "isPost": {
      "type": "computed",
      "value": "(operation == \"POST\")"
    },
    "isPut": {
      "type": "computed",
      "value": "(operation == \"PUT\")"
    },
    "isPatch": {
      "type": "computed",
      "value": "(operation == \"PATCH\")"
    },
    "isDelete": {
      "type": "computed",
      "value": "(operation == \"DELETE\")"
    },
    "include-endpoint": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Include the endpoint mapping file"
    }
  },
  "sources": [
    {
      "source": ".",
      "include": [
        "CreateSample.cs",
        "CreateSample.Contracts.cs",
        "CreateSample.Endpoint.cs"
      ],
      "modifiers": [
        {
          "condition": "(!include-endpoint)",
          "exclude": [ "CreateSample.Endpoint.cs" ]
        }
      ]
    }
  ]
}
